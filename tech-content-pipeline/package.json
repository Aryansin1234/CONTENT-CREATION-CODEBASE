{
  "name": "tech-content-pipeline",
  "version": "1.0.0",
  "description": "AI-powered news-to-social automation pipeline",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "now": "ts-node src/index.ts --now",
    "worker": "ts-node src/workers/post-worker.ts",
    "worker:analytics": "ts-node src/workers/analytics-worker.ts",
    "worker:report": "ts-node src/workers/report-worker.ts",
    "worker:competitor": "ts-node src/workers/competitor-worker.ts",
    "worker:synthesis": "ts-node src/workers/synthesis-worker.ts",
    "worker:evergreen": "ts-node src/workers/evergreen-worker.ts",
    "worker:newsletter": "ts-node src/workers/newsletter-worker.ts",
    "worker:engagement": "ts-node src/workers/engagement-worker.ts",
    "cli": "ts-node src/cli.ts",
    "test": "jest"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.13.0",
    "commander": "^14.0.3",
    "google-trends-api": "^4.9.2",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.57.0",
    "pdfkit": "^0.15.0",
    "puppeteer": "^23.0.0",
    "replicate": "^0.32.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.1",
    "twitter-api-v2": "^1.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/pdfkit": "^0.13.4",
    "dotenv": "^16.4.5",
    "jest": "^30.4.2",
    "msw": "^2.14.6",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
